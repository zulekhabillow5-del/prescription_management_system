.topbar{
    background:#0d6efd;
    color:#fff;
    height:70px;
    padding:15px 30px;
    display:flex;
    justify-content:space-between;
    align-items:center;
    box-shadow:0 2px 10px rgba(0,0,0,.15);
}

.topbar h4{
    margin:0;
    font-weight:bold;
}

.topbar .doctor{
    text-align:right;
}
